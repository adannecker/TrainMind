POSTGRES_DB=trainmind
POSTGRES_USER=trainmind
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg2://trainmind:change-me@localhost:5432/trainmind
# Used by Docker services (internal network host is `postgres`)
DATABASE_URL_DOCKER=postgresql+psycopg2://trainmind:change-me@postgres:5432/trainmind

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=replace-me

# Add your public URL or VPS IP origin if you need cross-origin API calls.
# For the bundled nginx frontend on the same host, /api works without extra CORS in the browser.
APP_CORS_ORIGINS=http://localhost,http://127.0.0.1,http://YOUR_SERVER_IP

# Optional provider/API credentials
OPENAI_API_KEY=
GARMIN_EMAIL=
GARMIN_PASSWORD=
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REDIRECT_URI=
WITHINGS_SCOPES=user.activity,user.metrics

# Optional public HTTP port on the VPS
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443
PUBLIC_DOMAIN=trainmind.de
LETSENCRYPT_EMAIL=info@trainmind.de
APP_BASE_URL=https://trainmind.de

# Optional invite email delivery via SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_SSL=false
SMTP_USE_STARTTLS=true
SMTP_FROM_EMAIL=no-reply@trainmind.de
SMTP_FROM_NAME=TrainMind
SMTP_REPLY_TO=no-reply@trainmind.de
SMTP_TIMEOUT_SECONDS=15
