POSTGRES_DB=trainmind
POSTGRES_USER=trainmind
POSTGRES_PASSWORD=trainmind
DATABASE_URL=postgresql+psycopg2://trainmind:trainmind@localhost:5432/trainmind
# Used by Docker services (internal network host is `postgres`)
DATABASE_URL_DOCKER=postgresql+psycopg2://trainmind:trainmind@postgres:5432/trainmind
# Fernet key for encrypted credential storage in DB.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=

# Garmin
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Withings
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REDIRECT_URI=
WITHINGS_SCOPES=user.activity,user.metrics
